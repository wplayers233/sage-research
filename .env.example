# ===== LLM (choose one provider) =====
# Model name determines which provider is used (prefix-based auto-detection)
LLM_MODEL_ID="deepseek-v4-flash"

# DeepSeek (default) — https://platform.deepseek.com
DEEPSEEK_API_KEY="your-deepseek-api-key"
DEEPSEEK_BASE_URL="https://api.deepseek.com"

# Zhipu GLM — https://open.bigmodel.cn
# GLM_API_KEY="your-glm-api-key"
# GLM_BASE_URL="https://open.bigmodel.cn/api/paas/v4/"

# Google Gemini — https://aistudio.google.com/apikey
# GOOGLE_API_KEY="your-google-api-key"
# GOOGLE_BASE_URL="https://generativelanguage.googleapis.com/v1beta/openai/"

# OpenAI — https://platform.openai.com
# OPENAI_API_KEY="your-openai-api-key"

# Anthropic Claude — https://console.anthropic.com
# ANTHROPIC_API_KEY="your-anthropic-api-key"

# Alibaba Qwen — https://dashscope.console.aliyun.com
# QWEN_API_KEY="your-qwen-api-key"
# QWEN_BASE_URL="https://dashscope.aliyuncs.com/compatible-mode/v1"

# ===== Embedding =====
EMBEDDING_MODEL_ID="embedding-3"
EMBEDDING_BASE_URL="https://open.bigmodel.cn/api/paas/v4/"

# ===== Search (at least one required, both have free tier) =====
BRAVE_API_KEY="your-brave-api-key"
TAVILY_API_KEY="your-tavily-api-key"

# ===== Optional =====
# REVIEW_MODEL_ID="qwen3.7-plus"  # Cross-model review: use a different LLM for quality review
# GITHUB_TOKEN="your-github-token"
# HF_TOKEN="your-hf-token"
# http_proxy="http://127.0.0.1:7897"
# https_proxy="http://127.0.0.1:7897"
